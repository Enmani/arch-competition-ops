{
  "name": "@arch-competition/web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "write:preview-revisions": "node ../../scripts/write-opportunity-preview-revisions.mjs",
    "dev": "npm run write:preview-revisions && next dev --port 3400",
    "build": "npm run write:preview-revisions && next build",
    "prepare:cloudflare-build": "powershell -ExecutionPolicy Bypass -File ../../scripts/prepare-cloudflare-build.ps1",
    "sync:satellite-previews": "npm run write:preview-revisions && node ../../scripts/sync-satellite-previews.mjs",
    "build:cloudflare": "npm run prepare:cloudflare-build && npm run sync:satellite-previews && opennextjs-cloudflare build",
    "deploy:cloudflare": "npm run build:cloudflare && opennextjs-cloudflare deploy",
    "d1:create": "wrangler d1 create arch-competition-ops",
    "d1:migrate:local": "wrangler d1 migrations apply arch-competition-ops --local",
    "d1:migrate:remote": "wrangler d1 migrations apply arch-competition-ops --remote",
    "preview:cloudflare": "opennextjs-cloudflare preview",
    "start": "npm run write:preview-revisions && next start --port 3400",
    "lint": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "@arch-competition/core": "0.1.0",
    "@arch-competition/storage": "0.1.0",
    "@opennextjs/cloudflare": "^1.19.4",
    "d3-geo": "^3.1.1",
    "next": "^15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260429.1",
    "@types/d3-geo": "^3.1.0",
    "@types/topojson-client": "^3.1.5",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.5.15",
    "wrangler": "^4.86.0"
  }
}
